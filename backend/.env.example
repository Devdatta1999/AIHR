SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres
HF_API_TOKEN=hf_your_token_here
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
# Larger model for the HR Analytics chatbot (NL→SQL needs more headroom).
# You must "Agree and access" the model card on HF first.
HF_ANALYTICS_MODEL_ID=meta-llama/Llama-3.3-70B-Instruct
# Cosine similarity threshold for the semantic cache to count as a hit.
ANALYTICS_CACHE_THRESHOLD=0.70
# Min RAG score for an answer to be flagged as "used custom KB".
ANALYTICS_RAG_HIT_THRESHOLD=0.45

# Qdrant — used for both shortlist RAG and the analytics chatbot.
QDRANT_URL=http://localhost:6333

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_ORGANIZER_EMAIL=
COMPANY_NAME=Nimbus Labs
COMPANY_TAGLINE=AI that hires better
